# Disable MultiViews to prevent conflicts with mod_rewrite content negotiation
Options -MultiViews

RewriteEngine On

# 1. Redirect /index.html and /index directly to the root / (SEO best practice)
RewriteCond %{THE_REQUEST} \s/+(index|index\.html)[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 2. Redirect direct requests for any other .html file to its clean URL version
RewriteCond %{THE_REQUEST} \s/+(?!index\.html)(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3. Internally map clean URLs back to their corresponding .html files under the hood
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]
